{
  "build": {
    "markdownEngineProperties": {
      "alerts": {
        "Did You Know?": "alert alert-success"
      }
    },
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "docs/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "pdmdeploy/**"
        ]
      }
    ],
    "sitemap": {
      "baseUrl": "https://docs.bluebyte.biz",
      "priority": 1,
      "changefreq": "weekly"
    },
    "output": "docs",
    "template": [
      "default",
      "modern",
      "templates/bluebyte"
    ],
    "globalMetadata": {
      "_appName": "Help Center",
      "_appTitle": "Help Center",
      "_appFooter": "<div class='bbs-site-footer' style='width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);text-align:center;'>&copy; 2026 Blue Byte Systems Inc. All rights reserved.</div>",
      "_appLogoPath": "images/bluebyte-mark.png",
      "_appFaviconPath": "images/bluebyte-mark.png",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
