{
  "build": {
     "markdownEngineProperties": {
      "alerts": {
        "Did You Know?": "alert alert-success"
      }
    },
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "docs/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "sitemap": {
      "baseUrl": "https://docs.bluebyte.biz",
      "priority": 1,
      "changefreq": "weekly"
    },
    "output": "docs",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Help Center",
      "_appTitle": "Help Center",
      "_appFooter": "<span><a href='https://bluebyte.biz'>Blue Byte Systems Inc</a>. Built by Blue Byte Systems.</span>",
      "_appLogoPath": "images/fav.png",
      "_enableSearch": true,
      "pdf": false
    }
  }
}